{
  "name": "@astonagent/next",
  "version": "0.1.0",
  "description": "Next.js helpers for astonagent: createChatRoute, useAstonChat, SSE codecs.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo 'lint: skipped (no config)'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@astonagent/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18"
  },
  "devDependencies": {
    "@astonagent/config": "workspace:*",
    "@types/react": "^19.0.7",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
