# Required: at least one of these. Only models whose key is set appear in the UI.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_API_KEY=...   # for Ollama Cloud models — create one at https://ollama.com/settings/keys

# Optional: custom SQLite path (default ./aston.sqlite)
# ASTON_SQLITE_PATH=./aston.sqlite
